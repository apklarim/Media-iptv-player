<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:label="MEDYA IPTV Player"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.MediaIPTVPlayer">

        <activity
            android:name=".DualPlayerActivity"
            android:exported="false"/>

        <activity
            android:name=".HiddenGroupsActivity"
            android:exported="false"/>

        <activity
            android:name=".PlayerActivity"
            android:exported="false"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"/>

        <activity
            android:name=".ChannelListActivity"
            android:exported="false"/>

        <activity
            android:name=".PlaylistListActivity"
            android:exported="false"/>

        <activity
            android:name=".AddPlaylistActivity"
            android:exported="false"/>

        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category
                    android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

    </application>

</manifest>
