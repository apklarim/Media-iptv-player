<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- İnternet erişimi -->

    <uses-permission
        android:name="android.permission.INTERNET" />

    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_media_logo"
        android:roundIcon="@drawable/ic_media_logo"
        android:label="Media IPTV Player"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.AppCompat.DayNight.NoActionBar">

        <activity
            android:name=".AddPlaylistActivity" />

        <activity
            android:name=".M3uUrlActivity" />

        <activity
            android:name=".XtreamActivity" />

        <activity
            android:name=".SettingsActivity" />

        <activity
            android:name=".HiddenGroupsActivity" />

        <!-- Yeni eklendi -->
        <activity
            android:name=".GroupManagerActivity"
            android:exported="false" />

        <activity
            android:name=".PlaylistListActivity" />

        <activity
            android:name=".DualPlayerActivity"
            android:screenOrientation="landscape" />

        <activity
            android:name=".PlayerActivity"
            android:screenOrientation="landscape"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation" />

        <activity
            android:name=".ChannelListActivity" />

        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>

                <action
                    android:name="android.intent.action.MAIN" />

                <category
                    android:name="android.intent.category.LAUNCHER" />

            </intent-filter>

        </activity>

    </application>

</manifest>
