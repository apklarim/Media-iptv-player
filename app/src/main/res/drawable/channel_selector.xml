<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Basılı -->

    <item android:state_pressed="true">

        <shape android:shape="rectangle">

            <solid android:color="#0FA7B3"/>

            <stroke
                android:width="4dp"
                android:color="#FFFFFF"/>

            <corners android:radius="16dp"/>

        </shape>

    </item>

    <!-- Seçili -->

    <item android:state_selected="true">

        <shape android:shape="rectangle">

            <solid android:color="#19C5D2"/>

            <stroke
                android:width="4dp"
                android:color="#FFFFFF"/>

            <corners android:radius="16dp"/>

        </shape>

    </item>

    <!-- Odaklanmış (TV Kumandası) -->

    <item android:state_focused="true">

        <shape android:shape="rectangle">

            <solid android:color="#19C5D2"/>

            <stroke
                android:width="4dp"
                android:color="#FFFFFF"/>

            <corners android:radius="16dp"/>

        </shape>

    </item>

    <!-- Normal -->

    <item>

        <shape android:shape="rectangle">

            <solid android:color="#10232B"/>

            <stroke
                android:width="2dp"
                android:color="#2A4D57"/>

            <corners android:radius="16dp"/>

        </shape>

    </item>

</selector>
