<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Basılı Durum -->

    <item android:state_pressed="true">

        <shape>

            <solid android:color="#19C5D2"/>

            <corners
                android:radius="24dp"/>

            <stroke
                android:width="2dp"
                android:color="#FFFFFF"/>

        </shape>

    </item>

    <!-- Normal Durum -->

    <item>

        <shape>

            <solid android:color="#10232B"/>

            <corners
                android:radius="24dp"/>

            <stroke
                android:width="1dp"
                android:color="#203A45"/>

        </shape>

    </item>

</selector>
