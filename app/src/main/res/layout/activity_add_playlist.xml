<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050B12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Üst Bar -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#00ACC1"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="Liste Ekle"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <!-- M3U URL -->

        <Button
            android:id="@+id/btnM3uUrl"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="16dp"
            android:backgroundTint="#00BCD4"
            android:text="M3U URL EKLE"
            android:textColor="#FFFFFF"
            android:textSize="22sp"/>

        <!-- M3U Dosya -->

        <Button
            android:id="@+id/btnM3uFile"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:backgroundTint="#00BCD4"
            android:text="M3U DOSYASI SEÇ"
            android:textColor="#FFFFFF"
            android:textSize="22sp"/>

        <!-- Xtream -->

        <Button
            android:id="@+id/btnXtream"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="16dp"
            android:backgroundTint="#00BCD4"
            android:text="XTREAM CODES EKLE"
            android:textColor="#FFFFFF"
            android:textSize="22sp"/>

    </LinearLayout>

</ScrollView>
