<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07161D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Liste Ekle"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

        <Button
            android:id="@+id/btnM3uUrl"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/focus_selector"
            android:text="🌐  M3U URL EKLE&#10;İnternet üzerinden liste ekleyin"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <Button
            android:id="@+id/btnM3uFile"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/focus_selector"
            android:text="📁  M3U DOSYASI SEÇ&#10;Cihazdan .m3u dosyası seçin"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <Button
            android:id="@+id/btnXtream"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/focus_selector"
            android:text="🔐  XTREAM CODES EKLE&#10;Xtream hesabı ekleyin"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

    </LinearLayout>

</ScrollView>
