<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#303030">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#732A78"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:text="Media IPTV Player"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="24sp"/>

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:src="@android:drawable/ic_media_play"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/btnFile"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_weight="1"
            android:text="BELGE AĞACI AÇ"
            android:backgroundTint="#732A78"/>

        <Button
            android:id="@+id/btnUrl"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="URL AÇ"
            android:backgroundTint="#732A78"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/btnOld"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_weight="1"
            android:text="DOSYA SEÇİCİ (ESKİ)"
            android:backgroundTint="#732A78"/>

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="AYARLAR"
            android:backgroundTint="#732A78"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bir sonraki başlangıçta seçimi hatırla"
            android:textColor="#FFFFFF"/>

        <Switch
            android:id="@+id/swRemember"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</LinearLayout>
