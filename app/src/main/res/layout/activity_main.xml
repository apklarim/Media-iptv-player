<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07161D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEDYA IPTV PLAYER"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoş Geldiniz"
            android:textColor="#00E5B0"
            android:textSize="18sp"
            android:layout_marginTop="4dp" />

        <!-- SATIR 1 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="25dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnLiveTv"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/home_card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📺"
                    android:textSize="60sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CANLI TV"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnMovies"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/home_card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎬"
                    android:textSize="60sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FİLMLER"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- SATIR 2 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnSeries"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/home_card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚"
                    android:textSize="60sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DİZİLER"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPlaylists"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/home_card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗂️"
                    android:textSize="60sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LİSTELER"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- SATIR 3 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/home_card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️"
                    android:textSize="60sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AYARLAR"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/home_card_background"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="60sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FAVORİLER"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
