<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="zoom"
        app:show_timeout="5000"
        app:use_controller="true"
        app:show_rewind_button="true"
        app:show_fastforward_button="true"
        app:show_previous_button="false"
        app:show_next_button="false" />

    <ListView
        android:id="@+id/listChannels"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#CC000000"
        android:divider="#33FFFFFF"
        android:dividerHeight="1dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/playerButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/player_button_selector"
            android:text="◀ Önceki"
            android:textColor="#FFFFFF"
            android:visibility="visible" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/player_button_selector"
            android:text="Sonraki ▶"
            android:textColor="#FFFFFF"
            android:visibility="visible" />

    </LinearLayout>

</FrameLayout>
