<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050B12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Üst Başlık -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#00ACC1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Ayarlar"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Genel -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:paddingStart="30dp"
            android:text="⚙ Genel"
            android:textColor="#00BCD4"
            android:textSize="24sp"/>

        <Switch
            android:id="@+id/switchLastPlaylist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Son Listeyi Otomatik Aç"
            android:textColor="#FFFFFF"/>

        <Switch
            android:id="@+id/switchLastChannel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Son Kanalı Otomatik Aç"
            android:textColor="#FFFFFF"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#303030"/>

        <!-- Tema -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:paddingStart="30dp"
            android:text="🎨 Tema"
            android:textColor="#00BCD4"
            android:textSize="24sp"/>

        <RadioGroup
            android:id="@+id/themeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <RadioButton
                android:id="@+id/radioDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Koyu Tema"
                android:textColor="#FFFFFF"/>

            <RadioButton
                android:id="@+id/radioTurquoise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Turkuaz Tema"
                android:textColor="#FFFFFF"/>

            <RadioButton
                android:id="@+id/radioBlue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mavi Tema"
                android:textColor="#FFFFFF"/>

        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#303030"/>

        <!-- Video -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:paddingStart="30dp"
            android:text="▶ Video"
            android:textColor="#00BCD4"
            android:textSize="24sp"/>

        <Switch
            android:id="@+id/switchAutoHide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Player Butonlarını Otomatik Gizle"
            android:textColor="#FFFFFF"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#303030"/>

        <!-- Hakkında -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:paddingStart="30dp"
            android:text="ℹ Hakkında"
            android:textColor="#00BCD4"
            android:textSize="24sp"/>

        <Button
            android:id="@+id/btnAdultPin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/focus_selector"
            android:text="Yetişkin PIN Değiştir"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="16dp"
            android:background="@drawable/focus_selector"
            android:text="Media IPTV Player Hakkında"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>
